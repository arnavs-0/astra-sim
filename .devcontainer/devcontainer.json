{
    "name": "Astra-Sim",
    "image": "astra-sim:latest",
    
    "runArgs": [
        "--shm-size=8g"
    ],

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "ms-python.python"
            ]
        }
    },

    "overrideCommand": true
}